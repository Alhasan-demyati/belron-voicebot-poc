    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\"ok\": false, \"error_code\": \"UNAUTHORIZED\", \"message_for_agent\": \"Authentifizierung fehlgeschlagen.\"}",
        "options": {
          "responseCode": 401
        }
      },
      "id": "11111111-1111-1111-1111-111111111103",
      "name": "Respond 401",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        640,
        460
      ]
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || {};\nconst raw = (body.spoken_phone || '').toString();\nconst defaultCC = ($vars.CARGLASS_DEFAULT_COUNTRY_CODE || '+49');\nlet digits = raw.replace(/[^0-9+]/g, '');\nif (digits.startsWith('00')) digits = '+' + digits.slice(2);\nif (digits.startsWith('0')) digits = defaultCC + digits.slice(1);\nif (!digits.startsWith('+')) digits = defaultCC + digits;\nconst phone_e164_url = encodeURIComponent(digits);\nreturn [{ json: { phone_e164: digits, phone_e164_url, conversation_id: body.conversation_id || null, raw } }];\n"
      },
      "id": "11111111-1111-1111-1111-111111111104",
      "name": "Normalize Phone",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        640,
        220
      ]
    },
    {
      "parameters": {
        "url": "={{$vars.CARGLASS_SUPABASE_URL}}/rest/v1/customers?phone_e164=eq.{{$json.phone_e164_url}}&select=id,first_name,last_name,phone_e164,language",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{$vars.CARGLASS_SUPABASE_SERVICE_ROLE_KEY}}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{$vars.CARGLASS_SUPABASE_SERVICE_ROLE_KEY}}"
            }
          ]
        },
        "options": {
          "timeout": 8000
        }
      },
      "id": "11111111-1111-1111-1111-111111111105",
      "name": "Query Customer",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        860,
        220
      ]
    },
    {
      "parameters": {
        "url": "={{$vars.CARGLASS_SUPABASE_URL}}/rest/v1/appointments?customer_id=eq.{{ $('Query Customer').item.json.id || '00000000-0000-0000-0000-000000000000' }}&order=scheduled_start.desc&limit=3&select=booking_reference,status,scheduled_start,branch_id,branches(name)",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{$vars.CARGLASS_SUPABASE_SERVICE_ROLE_KEY}}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{$vars.CARGLASS_SUPABASE_SERVICE_ROLE_KEY}}"
            }
          ]
        },
        "options": {
          "timeout": 8000
        }
      },
      "id": "11111111-1111-1111-1111-111111111106",
      "name": "Query Recent Appointments",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1080,
        220
      ]
    },
    {
      "parameters": {
        "jsCode": "const customerItem = $('Query Customer').first();\nconst customer = customerItem && customerItem.json && customerItem.json.id ? customerItem.json : null;\nconst found = customer !== null;\nconst apptItems = $('Query Recent Appointments').all() || [];\nconst recent_appointments = apptItems\n  .map(it => it.json)\n  .filter(a => a && a.booking_reference)\n  .map(a => ({\n    booking_reference: a.booking_reference,\n    status: a.status,\n    scheduled_start: a.scheduled_start,\n    branch_name: a.branches ? a.branches.name : null,\n  }));\nreturn [{ json: { ok: true, data: { found, customer, recent_appointments } } }];\n"
      },
      "id": "11111111-1111-1111-1111-111111111107",
      "name": "Shape Response",
      "type": "n8n-nodes-base.code",
